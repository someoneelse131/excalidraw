# Excalidraw Configuration
# Copy this file to .env and adjust values for your server

# Domain where Excalidraw will be accessible
EXCALIDRAW_DOMAIN=excalidraw.kirby.rocks

# Port mapping (host:container)
EXCALIDRAW_PORT=41006

# Collaboration server (room-based WebSocket)
EXCALIDRAW_COLLAB_PORT=41007

# WebSocket domain for collaboration (used as build arg)
EXCALIDRAW_WS_DOMAIN=excalidraw-ws.kirby.rocks
